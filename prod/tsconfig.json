{
  "compilerOptions": {
    "target": "ES2019",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["screeps", "jest"],
    "rootDir": "."
  },
  "include": ["src/**/*.ts", "test/**/*.ts"]
}
